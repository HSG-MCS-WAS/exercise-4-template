@prefix td: <https://www.w3.org/2019/wot/td#> .
@prefix hctl: <https://www.w3.org/2019/wot/hypermedia#> .
@prefix wotsec: <https://www.w3.org/2019/wot/security#> .
@prefix was: <https://was-course.interactions.ics.unisg.ch/wake-up-ontology#> .
@prefix js: <https://www.w3.org/2019/wot/json-schema#> .
@prefix htv: <http://www.w3.org/2011/http#> .

<urn:mattress> a td:Thing, was:Mattress;
  td:title "A mattress that can be set to vibrate or idle";
  td:hasSecurityConfiguration [ a wotsec:NoSecurityScheme
    ];
  td:hasActionAffordance [ a td:ActionAffordance, was:SetState;
      td:name "Set the mattress state";
      td:hasForm [
          htv:methodName "PUT";
          hctl:hasTarget <http://localhost:1180/mattress/properties/state>;
          hctl:forContentType "application/json";
          hctl:hasOperationType td:invokeAction
        ];
      td:hasInputSchema [ a js:StringSchema, was:MattressState;
          js:enum "idle", "vibrating"
        ]
    ];
  td:hasPropertyAffordance [ a td:PropertyAffordance, was:ReadState, js:StringSchema;
      td:name "Read the mattress state";
      td:hasForm [
          htv:methodName "GET";
          hctl:hasTarget <http://localhost:1180/mattress/properties/state>;
          hctl:forContentType "application/json";
          hctl:hasOperationType td:readProperty
        ], [
          htv:methodName "GET";
          hctl:hasTarget <http://localhost:1180/mattress/properties/state/observable>;
          hctl:forContentType "application/json";
          hctl:hasOperationType td:observeProperty;
          hctl:forSubProtocol "longpoll"
        ];
      td:isObservable true
    ] .
